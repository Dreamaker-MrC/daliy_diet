---
import { Icon } from 'astro-icon/components';

interface Cat {
  key: string;
  label: string;
  icon: string;
  count: number;
}
interface Props {
  cats: Cat[];
  active: string;
}
const { cats, active } = Astro.props;
---

<nav
  class="sticky top-0 z-10 -mx-4 border-b border-stone-200/70 bg-stone-100/80 px-4 py-2.5 backdrop-blur-md dark:border-white/10 dark:bg-stone-950/80"
  aria-label="分类筛选"
>
  <div class="flex gap-2 overflow-x-auto">
    {
      cats.map((c) => (
        <button
          type="button"
          data-filter={c.key}
          aria-selected={c.key === active ? 'true' : 'false'}
          class="group inline-flex shrink-0 items-center gap-1.5 rounded-full border px-4 py-2 text-sm font-semibold transition-colors border-stone-200 bg-white text-stone-600 hover:border-amber-300 aria-selected:border-amber-500 aria-selected:bg-amber-500 aria-selected:text-white dark:border-white/10 dark:bg-stone-900 dark:text-stone-300 dark:aria-selected:border-amber-400 dark:aria-selected:bg-amber-500 dark:aria-selected:text-stone-950"
        >
          <Icon name={c.icon} class="h-4 w-4" aria-hidden="true" />
          {c.label}
          <span class="rounded-full bg-black/5 px-1.5 text-xs tabular-nums text-stone-500 group-aria-selected:bg-white/25 group-aria-selected:text-white dark:bg-white/10 dark:text-stone-400 dark:group-aria-selected:bg-black/20 dark:group-aria-selected:text-stone-950">
            {c.count}
          </span>
        </button>
      ))
    }
  </div>
</nav>
